QAAQ;AAAA,MACjB;AAAA,IACF;AAGA,UAAM,eAAe,OAAO,YAAiB;AAC3C,UAAI;AACF,cAAM,IAAI,mBAAmB,QAAQ,IAAI,EAAE,WAAW,CAAC,QAAQ,WAAW;AAC1E,cAAM,IAAI,EAAE,OAAO,UAAU,aAAa,qBAAqB,OAAO,SAAS;AAC/E,sBAAA;AAAA,MACF,SAAS,OAAO;AACd,gBAAQ,MAAM,0BAA0B,KAAK;AAC7C,cAAM,IAAI,EAAE,OAAO,UAAU,aAAa,oCAAoC,OAAO,OAAO;AAAA,MAC9F;AAAA,IACF;AAGA,UAAM,gBAAgB,OAAO,YAAiB;AAC5C,UAAI,CAAC,QAAQ,+CAA+C,EAAG;AAE/D,UAAI;AACF,cAAM,IAAI,mBAAmB,QAAQ,EAAE;AACvC,cAAM,IAAI,EAAE,OAAO,UAAU,aAAa,kBAAkB,OAAO,SAAS;AAC5E,sBAAA;AACA,4BAAA;AAAA,MACF,SAAS,OAAO;AACd,gBAAQ,MAAM,2BAA2B,KAAK;AAC9C,cAAM,IAAI,EAAE,OAAO,UAAU,aAAa,oCAAoC,OAAO,OAAO;AAAA,MAC9F;AAAA,IACF;AAGA,UAAM,oBAAoB,CAAC,YAAiB;AAAA,MAC1C,CAAC;AAAA,QACC,OAAO,QAAQ,YAAY,eAAe;AAAA,QAC1C,MAAM,QAAQ,YAAY,mBAAmB;AAAA,QAC7C,OAAO,MAAM,aAAa,OAAO;AAAA,MAAA,CAClC;AAAA,MACD,CAAC;AAAA,QACC,OAAO;AAAA,QACP,MAAM;AAAA,QACN,OAAO,MAAM,cAAc,OAAO;AAAA,MAAA,CACnC;AAAA,IAAA;AAIH,UAAM,cAAc,CAAC,YAAiB;AACpC,eAAS,QAAQ,aAAa,CAAC,KAAK,OAAO,QAAQ,YAAY,CAAC,KAAK,KAAK,YAAA,KAAiB;AAAA,IAC7F;AAUA,YAAQ;AAAA,MACN,OAAO;AAAA,IAAA,CACR;;;;;;;;;;;AAxQoB,UAAAA,MAAA,SAAA,EAAU,cAAY;;UAAG,qBAAO,aAAA,QAAY;AAAA,UAAS,OAAM;AAAA,UAAU,MAAK;AAAA,QAAA;2BAAzF,CAEU,GAAAC,QAAAC,UAAA,aAAA;;;;;gCAF+F,sBAEzG;AAAA,cAAA;AAAA;;;;;;;kPAOiDC,eAAAH,MAAA,QAAA,EAAS,MAAM,2LAIdA,MAAA,cAAA,CAAc,sMAIfA,MAAA,iBAAA,CAAiB,iMAIhBA,MAAA,aAAA,CAAa;UAMpDA,MAAA,OAAA,GAAO;;;UACT,MAAK;AAAA,UAAoB,OAAM;AAAA,QAAA;;MAGxB,WAAAA,MAAA,QAAA,EAAS,WAAM,GAAA;;;UACvB,MAAK;AAAA,UAAe,OAAM;AAAA,QAAA;;AAEjB,YAAAA,MAAA,SAAA,EAAU,cAAY;;YAAG,qBAAO,aAAA,QAAY;AAAA,YAAS,OAAM;AAAA,YAAU,OAAM;AAAA,UAAA;6BAA1F,CAEU,GAAAC,QAAAC,UAAA,aAAA;;;;;kCAFuF,8BAEjG;AAAA,gBAAA;AAAA;;;;;;;;;;AAIuBE,sBAAAJ,MAAA,QAAA,IAAX,YAAO;wHAG0DK,eAAA,CAAA,2DAAA,QAAQ,YAAS,iBAAA,aAAA,CAAA,mBAChDA,eAAA,CAAA,yBAAA,QAAQ,YAAS,mBAAA,eAAA,CAAA,MACpDF,eAAA,YAAY,OAAO,CAAA,+GAOkBA,eAAA,QAAQ,UAAU,KAAOA,eAAA,QAAQ,SAAS;;YACzE,OAAO,QAAQ,YAAS,UAAA;AAAA,YAAqB,SAAQ;AAAA,YAAO,MAAK;AAAA,UAAA;6BAA1E,CAES,GAAAF,QAAAC,UAAA,aAAA;;AADJD,uBAAA,GAAAE,eAAA,QAAQ,YAAS,UAAA,SAAA,CAAA,EAAA;AAAA;;kBAAjBG,gBAAAC,gBAAA,QAAQ,YAAS,UAAA,SAAA,GAAA,CAAA;AAAA,gBAAA;AAAA;;;;0DAGYJ,eAAA,QAAQ,KAAK,OAASA,eAAA,QAAQ,IAAI,mGAKtBA,eAAA,QAAQ,gBAAgB;;YAEhE,MAAK;AAAA,YAAc,OAAM;AAAA,UAAA;AACM,gBAAA,qCAAAA,eAAA,OAAO,QAAQ,MAAM,EAAE,QAAO,CAAA,CAAA,CAAA,qBAAA;AAKtD,cAAAH,MAAA,SAAA,EAAU,cAAY;;cAAG,OAAO,kBAAkB,OAAO;AAAA,cAAI,QAAQ,EAAA,WAAA,aAAA;AAAA,YAAA;+BAAtF,CAEY,GAAAC,QAAAC,UAAA,aAAA;;;oBADD,OAAM;AAAA,oBAAO,SAAQ;AAAA,oBAAQ,MAAK;AAAA,oBAAyB,MAAK;AAAA,kBAAA;;;oBAAzEM,YAAgF,oBAAA;AAAA,sBAAvE,OAAM;AAAA,sBAAO,SAAQ;AAAA,sBAAQ,MAAK;AAAA,sBAAyB,MAAK;AAAA,oBAAA;;;;;;;;;;;;;;;oBAQlER,MAAA,YAAA;AAAA,iEAAA,aAAY,QAAA,SAAA;AAAA,MAAA;yBAA7B,CA4BS,GAAAC,QAAAC,UAAA,aAAA;;;;0BAlBQF,MAAA,YAAA;AAAA,uEAAA,aAAY,QAAA,SAAA;AAAA,cACpB,SAASA,MAAA,cAAA;AAAA,cACV,oBAAiB;AAAA,cACjB,mBAAgB;AAAA,cAChB,aAAY;AAAA,cACZ,YAAA;AAAA,YAAA;;0BAGeA,MAAA,eAAA;AAAA,0EAAA,gBAAe,QAAA,SAAA;AAAA,cAAE,aAAY;AAAA,cAAY,MAAK;AAAA,YAAA;;0BAE9CA,MAAA,cAAA;AAAA,yEAAA,eAAc,QAAA,SAAA;AAAA,cAAE,aAAY;AAAA,cAAoB,MAAK;AAAA,YAAA;;;cAI7D,OAAM;AAAA,cAAO,SAAQ;AAAA,cAAW,qBAAO,aAAA,QAAY;AAAA,YAAA;+BAA5D,CAAuFS,IAAAR,QAAAC,UAAAQ,cAAA;;;;;oCAAjB,SAAO;AAAA,kBAAA;AAAA;;;;;cACpE,OAAM;AAAA,cAAW,SAASV,MAAA,MAAA;AAAA,cAAS,SAAO;AAAA,YAAA;+BAAnD,CAAgFS,IAAAR,QAAAC,UAAAQ,cAAA;;;;;oCAAjB,SAAO;AAAA,kBAAA;AAAA;;;;;;;cAxB1EF,YA0BM,OAAA,EA1BD,OAAM,SAAK;AAAA,gBACdA,YAA4E,MAAA,EAAxE,OAAM,2CAAA,GAA2C,oBAAkB;AAAA,gBAEvEA,YAiBM,OAAA,EAjBD,OAAM,eAAW;AAAA,kBACpBA,YAEI,KAAA,EAFD,OAAM,wBAAA,GAAwB,6FAEjC;AAAA,kBAEAA,YAOE,wBAAA;AAAA,gCANSR,MAAA,YAAA;AAAA,6EAAA,aAAY,QAAA,SAAA;AAAA,oBACpB,SAASA,MAAA,cAAA;AAAA,oBACV,oBAAiB;AAAA,oBACjB,mBAAgB;AAAA,oBAChB,aAAY;AAAA,oBACZ,YAAA;AAAA,kBAAA;kBAGFQ,YAAkF,mBAAA;AAAA,gCAAjER,MAAA,eAAA;AAAA,gFAAA,gBAAe,QAAA,SAAA;AAAA,oBAAE,aAAY;AAAA,oBAAY,MAAK;AAAA,kBAAA;kBAE/DQ,YAA2F,mBAAA;AAAA,gCAA1ER,MAAA,cAAA;AAAA,+EAAA,eAAc,QAAA,SAAA;AAAA,oBAAE,aAAY;AAAA,oBAAoB,MAAK;AAAA,kBAAA;;gBAGxEQ,YAGM,OAAA,EAHD,OAAM,iCAA6B;AAAA,kBACtCA,YAAuF,oBAAA;AAAA,oBAA9E,OAAM;AAAA,oBAAO,SAAQ;AAAA,oBAAW,qBAAO,aAAA,QAAY;AAAA,kBAAA;qCAAU,MAAO;AAAA,sCAAP,SAAO;AAAA,oBAAA;;;kBAC7EA,YAAgF,oBAAA;AAAA,oBAAvE,OAAM;AAAA,oBAAW,SAASR,MAAA,MAAA;AAAA,oBAAS,SAAO;AAAA,kBAAA;qCAAY,MAAO;AAAA,sCAAP,SAAO;AAAA,oBAAA;;;;;;;;;;;;;;;;;;;;","names":["_unref","_push","_parent","_ssrInterpolate","_ssrRenderList","_ssrRenderClass","_createTextVNode","_toDisplayString","_createVNode","_","_scopeId"],"sources":["../../../../pages/admin/livreurs/index.vue"],"sourcesContent":["<template>\n  <div>\n    <!-- Header -->\n    <div class=\"mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n      <div>\n        <h1 class=\"text-2xl font-bold text-gray-900\">Livreurs</h1>\n        <p class=\"text-gray-500 mt-1\">Gérez votre équipe de livreurs</p>\n      </div>\n      <UButton v-if=\"authStore.isSuperAdmin\" @click=\"showAddModal = true\" color=\"primary\" icon=\"i-lucide-plus\">\n        Ajouter un livreur\n      </UButton>\n    </div>\n\n    <!-- Stats -->\n    <div class=\"grid grid-cols-1 md:grid-cols-4 gap-4 mb-6\">\n      <div class=\"bg-white rounded-xl p-4 shadow-sm border border-gray-100\">\n        <p class=\"text-sm text-gray-500\">Total livreurs</p>\n        <p class=\"text-2xl font-bold text-gray-900\">{{ livreurs.length }}</p>\n      </div>\n      <div class=\"bg-white rounded-xl p-4 shadow-sm border border-gray-100\">\n        <p class=\"text-sm text-gray-500\">Actifs</p>\n        <p class=\"text-2xl font-bold text-green-600\">{{ activeLivreurs }}</p>\n      </div>\n      <div class=\"bg-white rounded-xl p-4 shadow-sm border border-gray-100\">\n        <p class=\"text-sm text-gray-500\">Livraisons ce mois</p>\n        <p class=\"text-2xl font-bold text-gray-900\">{{ monthlyDeliveries }}</p>\n      </div>\n      <div class=\"bg-white rounded-xl p-4 shadow-sm border border-gray-100\">\n        <p class=\"text-sm text-gray-500\">Note moyenne</p>\n        <p class=\"text-2xl font-bold text-amber-600\">{{ averageRating }}/5</p>\n      </div>\n    </div>\n\n    <!-- Livreurs List -->\n    <div class=\"bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden\">\n      <div v-if=\"loading\" class=\"p-8 text-center\">\n        <UIcon name=\"i-lucide-loader-2\" class=\"w-8 h-8 animate-spin text-primary-500 mx-auto\" />\n      </div>\n      \n      <div v-else-if=\"livreurs.length === 0\" class=\"p-8 text-center\">\n        <Icon name=\"lucide:truck\" class=\"w-12 h-12 mx-auto text-gray-300 mb-3\" />\n        <p class=\"text-gray-500\">Aucun livreur pour le moment</p>\n        <UButton v-if=\"authStore.isSuperAdmin\" @click=\"showAddModal = true\" color=\"primary\" class=\"mt-4\">\n          Ajouter le premier livreur\n        </UButton>\n      </div>\n\n      <div v-else class=\"divide-y divide-gray-100\">\n        <div v-for=\"livreur in livreurs\" :key=\"livreur.id\" class=\"p-4 hover:bg-gray-50 transition-colors\">\n          <div class=\"flex items-center gap-4\">\n            <!-- Avatar -->\n            <div :class=\"['w-12 h-12 rounded-full flex items-center justify-center', livreur.is_active ? 'bg-green-100' : 'bg-gray-100']\">\n              <span :class=\"['text-lg font-semibold', livreur.is_active ? 'text-green-700' : 'text-gray-500']\">\n                {{ getInitials(livreur) }}\n              </span>\n            </div>\n\n            <!-- Info -->\n            <div class=\"flex-1\">\n              <div class=\"flex items-center gap-2\">\n                <p class=\"font-medium text-gray-900\">{{ livreur.first_name }} {{ livreur.last_name }}</p>\n                <UBadge :color=\"livreur.is_active ? 'green' : 'gray'\" variant=\"soft\" size=\"xs\">\n                  {{ livreur.is_active ? 'Actif' : 'Inactif' }}\n                </UBadge>\n              </div>\n              <p class=\"text-sm text-gray-500\">{{ livreur.phone }} · {{ livreur.zone }}</p>\n            </div>\n\n            <!-- Stats -->\n            <div class=\"text-right hidden sm:block\">\n              <p class=\"text-sm font-medium text-gray-900\">{{ livreur.total_deliveries }} livraisons</p>\n              <div class=\"flex items-center justify-end gap-1 text-amber-500\">\n                <Icon name=\"lucide:star\" class=\"w-4 h-4 fill-current\" />\n                <span class=\"text-sm font-medium\">{{ Number(livreur.rating).toFixed(1) }}</span>\n              </div>\n            </div>\n\n            <!-- Actions -->\n            <UDropdown v-if=\"authStore.isSuperAdmin\" :items=\"getLivreurActions(livreur)\" :popper=\"{ placement: 'bottom-end' }\">\n              <UButton color=\"gray\" variant=\"ghost\" icon=\"i-lucide-more-vertical\" size=\"sm\" />\n            </UDropdown>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Add Livreur Modal -->\n    <UModal v-model=\"showAddModal\">\n      <div class=\"p-6\">\n        <h3 class=\"text-lg font-semibold text-gray-900 mb-4\">Ajouter un livreur</h3>\n        \n        <div class=\"space-y-4\">\n          <p class=\"text-sm text-gray-500\">\n            Sélectionnez un utilisateur existant ou créez-en un nouveau pour l'ajouter comme livreur.\n          </p>\n          \n          <USelectMenu\n            v-model=\"selectedUser\"\n            :options=\"availableUsers\"\n            option-attribute=\"label\"\n            value-attribute=\"value\"\n            placeholder=\"Sélectionner un utilisateur\"\n            searchable\n          />\n\n          <UInput v-model=\"newLivreurPhone\" placeholder=\"Téléphone\" icon=\"i-lucide-phone\" />\n          \n          <UInput v-model=\"newLivreurZone\" placeholder=\"Zone de livraison\" icon=\"i-lucide-map-pin\" />\n        </div>\n\n        <div class=\"flex justify-end gap-3 mt-6\">\n          <UButton color=\"gray\" variant=\"outline\" @click=\"showAddModal = false\">Annuler</UButton>\n          <UButton color=\"primary\" :loading=\"saving\" @click=\"addLivreur\">Ajouter</UButton>\n        </div>\n      </div>\n    </UModal>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefinePageMeta({\n  layout: 'admin',\n  middleware: ['admin']\n})\n\nconst authStore = useAuthStore()\nconst api = useBackendApi()\nconst toast = useToast()\n\n// State\nconst loading = ref(true)\nconst saving = ref(false)\nconst livreurs = ref<any[]>([])\n\n// Add modal\nconst showAddModal = ref(false)\nconst selectedUser = ref<string | null>(null)\nconst newLivreurPhone = ref('')\nconst newLivreurZone = ref(\"N'Djamena\")\nconst availableUsers = ref<{ label: string; value: string }[]>([])\n\n// Computed stats\nconst activeLivreurs = computed(() => livreurs.value.filter(l => l.is_active).length)\nconst monthlyDeliveries = computed(() => livreurs.value.reduce((sum, l) => sum + (l.total_deliveries || 0), 0))\nconst averageRating = computed(() => {\n  if (livreurs.value.length === 0) return '0.0'\n  const total = livreurs.value.reduce((sum, l) => sum + Number(l.rating || 5), 0)\n  return (total / livreurs.value.length).toFixed(1)\n})\n\n// Fetch livreurs\nconst fetchLivreurs = async () => {\n  loading.value = true\n  try {\n    const result = await api.adminLivreurs()\n    livreurs.value = result?.data || []\n  } catch (error) {\n    console.error('Error fetching livreurs:', error)\n    toast.add({ title: 'Erreur', description: 'Impossible de charger les livreurs', color: 'red' })\n  } finally {\n    loading.value = false\n  }\n}\n\n// Fetch available users (clients who can be promoted to livreur)\nconst fetchAvailableUsers = async () => {\n  try {\n    const result = await api.adminClients()\n    if (result?.data) {\n      availableUsers.value = result.data.map((u: any) => ({\n        label: `${u.first_name} ${u.last_name} (${u.email})`,\n        value: u.id\n      }))\n    }\n  } catch (error) {\n    console.error('Error fetching available users:', error)\n  }\n}\n\n// Add livreur\nconst addLivreur = async () => {\n  if (!selectedUser.value || !newLivreurPhone.value) {\n    toast.add({ title: 'Erreur', description: 'Veuillez remplir tous les champs', color: 'red' })\n    return\n  }\n\n  saving.value = true\n  try {\n    // Find the selected user info\n    const userInfo = availableUsers.value.find(u => u.value === selectedUser.value)\n    const nameParts = (userInfo?.label || '').split(' ')\n    \n    await api.adminLivreurCreate({\n      user_id: selectedUser.value,\n      first_name: nameParts[0] || '',\n      last_name: nameParts[1] || '',\n      email: '',\n      phone: newLivreurPhone.value,\n      zone: newLivreurZone.value || \"N'Djamena\",\n    })\n\n    toast.add({ title: 'Succès', description: 'Livreur ajouté avec succès', color: 'green' })\n    showAddModal.value = false\n    selectedUser.value = null\n    newLivreurPhone.value = ''\n    newLivreurZone.value = \"N'Djamena\"\n    fetchLivreurs()\n    fetchAvailableUsers()\n  } catch (error) {\n    console.error('Error adding livreur:', error)\n    toast.add({ title: 'Erreur', description: \"Impossible d'ajouter le livreur\", color: 'red' })\n  } finally {\n    saving.value = false\n  }\n}\n\n// Toggle livreur status\nconst toggleStatus = async (livreur: any) => {\n  try {\n    await api.adminLivreurUpdate(livreur.id, { is_active: !livreur.is_active })\n    toast.add({ title: 'Succès', description: 'Statut mis à jour', color: 'green' })\n    fetchLivreurs()\n  } catch (error) {\n    console.error('Error toggling status:', error)\n    toast.add({ title: 'Erreur', description: 'Impossible de modifier le statut', color: 'red' })\n  }\n}\n\n// Remove livreur\nconst removeLivreur = async (livreur: any) => {\n  if (!confirm('Êtes-vous sûr de vouloir retirer ce livreur ?')) return\n\n  try {\n    await api.adminLivreurDelete(livreur.id)\n    toast.add({ title: 'Succès', description: 'Livreur retiré', color: 'green' })\n    fetchLivreurs()\n    fetchAvailableUsers()\n  } catch (error) {\n    console.error('Error removing livreur:', error)\n    toast.add({ title: 'Erreur', description: 'Impossible de retirer le livreur', color: 'red' })\n  }\n}\n\n// Get actions for dropdown\nconst getLivreurActions = (livreur: any) => [\n  [{\n    label: livreur.is_active ? 'Désactiver' : 'Activer',\n    icon: livreur.is_active ? 'i-lucide-pause' : 'i-lucide-play',\n    click: () => toggleStatus(livreur)\n  }],\n  [{\n    label: 'Retirer',\n    icon: 'i-lucide-trash-2',\n    click: () => removeLivreur(livreur)\n  }]\n]\n\n// Helpers\nconst getInitials = (livreur: any) => {\n  return ((livreur.first_name?.[0] || '') + (livreur.last_name?.[0] || '')).toUpperCase() || '?'\n}\n\n// Fetch on mount\nonMounted(() => {\n  fetchLivreurs()\n  if (authStore.isSuperAdmin) {\n    fetchAvailableUsers()\n  }\n})\n\nuseHead({\n  title: 'Livreurs - Admin TchadBox'\n})\n</script>\n\n"],"version":3}
{"file":"suivi-CiwDwjtF.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;AAqJA,UAAM,cAAc,IAAI,EAAE;AAC1B,UAAM,QAAQ,IAAS,IAAI;AAC3B,UAAM,WAAW,IAAI,KAAK;AAC1B,UAAM,cAAc,IAAI,KAAK;AAE7B,UAAM,mBAAmB,SAAS,MAAM;AACtC,UAAI,CAAC,MAAM,MAAO,QAAO;AACzB,YAAM,YAAY,MAAM,MAAM,SAAS,OAAO,CAAC,MAAW,EAAE,SAAS,EAAE;AACvE,aAAQ,YAAY,MAAM,MAAM,SAAS,SAAU;AAAA,IACrD,CAAC;AA+CD,YAAQ,EAAE,OAAO,sBAAsB;;;;;QArMnB,SAAS,EAAA,SAAA,GAAA,GAAA,GAAA;AAAA,QAAwB,OAAO,EAAA,SAAA,GAAA,GAAA,EAAA;AAAA,QAClD,OAAM;AAAA,MAAA;AAEE,YAAAA,mBAAAC,MAAA,MAAA,GAAA,EAAA,OAAM,0CAAA,GAAyC,MAAA,OAAA,CAAA;;QAG7C,SAAS,EAAA,SAAA,GAAA,GAAA,GAAA;AAAA,QAAwB,OAAO,EAAA,SAAA,GAAA,GAAA,GAAA,YAAA,EAAA,OAAA,MAAA;AAAA,QAClD,OAAM;AAAA,MAAA;QAKI,SAAS,EAAA,SAAA,GAAA,GAAA,GAAA;AAAA,QAAwB,OAAO,EAAA,SAAA,GAAA,GAAA,GAAA,YAAA,EAAA,OAAA,MAAA;AAAA,QAClD,OAAM;AAAA,MAAA;AAcI,YAAAD,mBAAAC,MAAA,IAAA,GAAA,EAAA,OAAM,kFAAA,GAAiF,MAAA,OAAA,CAAA;4CAElFA,MAAA,WAAA,CAAW,iIAOSA,MAAA,WAAA,CAAW,IAAA,cAAA;UAE1BA,MAAA,WAAA,GAAW;AAAE,cAAAD,mBAAAC,MAAA,MAAA,GAAA,EAAA,OAAM,uBAAA,GAAsB,MAAA,OAAA,CAAA;AAAA;AACxC,cAAAD,mBAAAC,MAAA,MAAA,GAAA,EAAA,OAAM,UAAA,GAAS,MAAA,OAAA,CAAA;AAAA;;AAMvB,YAAAD,mBAAAC,MAAA,SAAA,GAAA,EAAA,OAAM,qCAAA,GAAoC,MAAA,OAAA,CAAA;;UAY9CA,MAAA,KAAA,GAAK;sPAMkCC,eAAAD,MAAA,KAAA,EAAM,MAAM,2BAG9CE,eAAA,CAAAF,MAAA,KAAA,EAAM,YAAS,mCAAA,kCAAA,4CAAA,CAAA,MAEpBC,eAAAD,MAAA,KAAA,EAAM,YAAS,YAAA,YAAA,2TAYGA,MAAA,gBAAA,CAAgB,IAAA,CAAA;AAGdG,sBAAAH,MAAA,KAAA,EAAM,UAAQ,CAA1B,MAAM,MAAC;AAIR,gBAAA,0DAAAE,eAAA,CAAA,KAAK;AAIA,cAAA,KAAK,WAAS;AAAE,kBAAAH,mBAAAC,MAAA,KAAA,GAAA,EAAA,OAAM,UAAA,GAAS,MAAA,OAAA,CAAA;AAAA;AACrBI,2BAAA,OAAAC,YAAAC,wBAAA,KAAK,IAAI,GAAA,EAAE,OAAM,UAAA,GAAS,IAAA,GAAA,OAAA;AAAA;wCAI0CJ,eAAA,CAAA,EAAA,+BAAA,KAAK,aAAS,wCAAA,CAAA,MACpGD,eAAA,KAAK,KAAK,0DAEsCA,eAAA,KAAK,IAAI;AACrD,cAAA,KAAK,QAAM;AAA6D,kBAAA,8DAAAA,eAAA,KAAK,MAAM,CAAA,MAAA;AAAA;;;;;;;UAQxF,IAAG;AAAA,UAAW,OAAM;AAAA,QAAA;2BAA9B,CAEW,GAAAM,QAAAC,UAAA,aAAA;;;AADYD,qBAAAR,mBAAAC,MAAA,aAAA,GAAA,EAAA,OAAM,aAAS,MAAAQ,UAAA,QAAA,CAAA;;;;gBAApCH,YAAkE,QAAA,MAAA;AAAA,kBAA5DA,YAAiCL,MAAA,aAAA,GAAA,EAAlB,OAAM,WAAS;AAAA,kCAAG,sBAAoB;AAAA,gBAAA;;;;;;;;;;UAYtDA,MAAA,QAAA,GAAQ;;AAEN,cAAAD,mBAAAC,MAAA,OAAA,GAAA,EAAA,OAAM,uBAAA,GAAsB,MAAA,OAAA,CAAA;;;UAM7B,IAAG;AAAA,UAAW,OAAM;AAAA,QAAA;2BAA9B,CAEW,GAAAO,QAAAC,UAAA,aAAA;;;AADYD,qBAAAR,mBAAAC,MAAA,aAAA,GAAA,EAAA,OAAM,aAAS,MAAAQ,UAAA,QAAA,CAAA;;;;gBAApCH,YAA4D,QAAA,MAAA;AAAA,kBAAtDA,YAAiCL,MAAA,aAAA,GAAA,EAAlB,OAAM,WAAS;AAAA,kCAAG,gBAAc;AAAA,gBAAA;;;;;;;;;;;;;;;;;;;;","names":["_ssrRenderComponent","_unref","_ssrInterpolate","_ssrRenderClass","_ssrRenderList","_ssrRenderVNode","_createVNode","_resolveDynamicComponent","_push","_parent"],"sources":["../../../../pages/suivi.vue"],"sourcesContent":["<template>\n  <div>\n    <!-- Hero -->\n    <section class=\"relative py-20 bg-[var(--color-bg-warm)] overflow-hidden\">\n      <div class=\"orb orb-amber w-80 h-80 -top-20 -right-20 opacity-10\" />\n      \n      <div class=\"container-main relative text-center\">\n        <div \n          v-motion :initial=\"{ opacity: 0, y: 10 }\" :enter=\"{ opacity: 1, y: 0 }\"\n          class=\"w-16 h-16 mx-auto rounded-2xl bg-[var(--color-accent)]/10 flex items-center justify-center mb-5\"\n        >\n          <MapPin class=\"w-8 h-8 text-[var(--color-accent-dark)]\" />\n        </div>\n        <h1 \n          v-motion :initial=\"{ opacity: 0, y: 20 }\" :enter=\"{ opacity: 1, y: 0, transition: { delay: 100 } }\"\n          class=\"heading-section mb-4\"\n        >\n          Suivre ma <span class=\"text-gradient\">commande</span>\n        </h1>\n        <p \n          v-motion :initial=\"{ opacity: 0, y: 20 }\" :enter=\"{ opacity: 1, y: 0, transition: { delay: 200 } }\"\n          class=\"text-lg text-[var(--color-text-muted)] max-w-lg mx-auto\"\n        >\n          Saisissez votre numéro de commande pour suivre son acheminement en temps réel\n        </p>\n      </div>\n    </section>\n\n    <div class=\"container-main py-12 max-w-2xl\">\n      <!-- Search Form -->\n      <div class=\"card p-8 mb-8\">\n        <form @submit.prevent=\"trackOrder\">\n          <label class=\"block text-sm font-medium text-[var(--color-text)] mb-3\">Numéro de commande</label>\n          <div class=\"flex gap-4\">\n            <div class=\"relative flex-grow\">\n              <Hash class=\"absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-[var(--color-text-muted)]\" />\n              <input \n                v-model=\"orderNumber\" \n                type=\"text\" \n                placeholder=\"Ex: TCB-2024-001234\" \n                class=\"input pl-12\" \n                required \n              />\n            </div>\n            <button type=\"submit\" :disabled=\"isSearching\" class=\"btn-gold flex-shrink-0\">\n              <span>\n                <Loader v-if=\"isSearching\" class=\"w-5 h-5 animate-spin\" />\n                <Search v-else class=\"w-5 h-5\" />\n                Rechercher\n              </span>\n            </button>\n          </div>\n          <p class=\"text-sm text-[var(--color-text-muted)] mt-3 flex items-center gap-2\">\n            <Lightbulb class=\"w-4 h-4 text-[var(--color-accent)]\" />\n            Entrez le numéro reçu par email après votre commande\n          </p>\n        </form>\n      </div>\n\n      <!-- Order Found -->\n      <Transition\n        enter-active-class=\"transition-all duration-500\"\n        enter-from-class=\"opacity-0 translate-y-4\"\n        enter-to-class=\"opacity-100 translate-y-0\"\n      >\n        <div v-if=\"order\" class=\"card overflow-hidden\">\n          <!-- Order header -->\n          <div class=\"bg-[var(--color-primary)] text-white p-6\">\n            <div class=\"flex justify-between items-center\">\n              <div>\n                <p class=\"text-sm text-white/60 mb-1\">Commande</p>\n                <p class=\"text-xl font-bold font-mono\">{{ order.number }}</p>\n              </div>\n              <span class=\"px-4 py-2 rounded-xl text-sm font-semibold\"\n                :class=\"order.delivered ? 'bg-green-500/20 text-green-300' : 'bg-amber-500/20 text-amber-300'\"\n              >\n                {{ order.delivered ? '✓ Livré' : '⏳ En cours' }}\n              </span>\n            </div>\n          </div>\n          \n          <!-- Timeline -->\n          <div class=\"p-6\">\n            <div class=\"relative\">\n              <!-- Vertical line -->\n              <div class=\"absolute left-[15px] top-2 bottom-2 w-0.5 bg-gray-100\" />\n              <div \n                class=\"absolute left-[15px] top-2 w-0.5 bg-gradient-to-b from-[var(--color-accent)] to-[var(--color-success)] transition-all duration-1000\"\n                :style=\"{ height: `${completedPercent}%` }\"\n              />\n              \n              <div v-for=\"(step, i) in order.timeline\" :key=\"i\" class=\"relative pl-12 pb-8 last:pb-0\">\n                <!-- Step circle -->\n                <div \n                  class=\"absolute left-0 w-8 h-8 rounded-xl flex items-center justify-center transition-all duration-300\"\n                  :class=\"step.completed \n                    ? 'bg-[var(--color-success)] text-white shadow-md shadow-green-500/20' \n                    : 'bg-gray-100 text-gray-400'\"\n                >\n                  <Check v-if=\"step.completed\" class=\"w-4 h-4\" />\n                  <component v-else :is=\"step.icon\" class=\"w-4 h-4\" />\n                </div>\n                \n                <div>\n                  <p class=\"font-semibold text-[var(--color-text)]\" :class=\"{ 'text-[var(--color-success)]': step.completed }\">\n                    {{ step.title }}\n                  </p>\n                  <p class=\"text-sm text-[var(--color-text-muted)]\">{{ step.date }}</p>\n                  <p v-if=\"step.detail\" class=\"text-sm text-[var(--color-text-secondary)] mt-1\">{{ step.detail }}</p>\n                </div>\n              </div>\n            </div>\n          </div>\n          \n          <!-- Order footer -->\n          <div class=\"px-6 pb-6 flex gap-3\">\n            <NuxtLink to=\"/contact\" class=\"btn-outline flex-1 text-center text-sm\">\n              <span><MessageCircle class=\"w-4 h-4\" />Contacter le support</span>\n            </NuxtLink>\n          </div>\n        </div>\n      </Transition>\n\n      <!-- Not Found -->\n      <Transition\n        enter-active-class=\"transition-all duration-300\"\n        enter-from-class=\"opacity-0 scale-95\"\n        enter-to-class=\"opacity-100 scale-100\"\n      >\n        <div v-if=\"notFound\" class=\"card p-12 text-center\">\n          <div class=\"w-16 h-16 rounded-2xl bg-red-50 flex items-center justify-center mx-auto mb-4\">\n            <SearchX class=\"w-8 h-8 text-red-300\" />\n          </div>\n           <h3 class=\"text-xl font-semibold text-[var(--color-text)] mb-2\">Commande introuvable</h3>\n           <p class=\"text-[var(--color-text-muted)] mb-6 max-w-sm mx-auto\">\n             Vérifiez votre numéro de commande et réessayez. Si le problème persiste, notre équipe est disponible pour vous aider.\n           </p>\n          <NuxtLink to=\"/contact\" class=\"btn-outline\">\n            <span><MessageCircle class=\"w-4 h-4\" />Nous contacter</span>\n          </NuxtLink>\n        </div>\n      </Transition>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { MapPin, Search, Check, SearchX, Hash, Lightbulb, MessageCircle, Loader, Package, CreditCard, Truck, Camera, Clock } from 'lucide-vue-next'\n\nconst orderNumber = ref('')\nconst order = ref<any>(null)\nconst notFound = ref(false)\nconst isSearching = ref(false)\n\nconst completedPercent = computed(() => {\n  if (!order.value) return 0\n  const completed = order.value.timeline.filter((s: any) => s.completed).length\n  return (completed / order.value.timeline.length) * 100\n})\n\nconst trackOrder = async () => {\n  order.value = null\n  notFound.value = false\n  isSearching.value = true\n  \n  const { client } = useSupabase()\n  \n  try {\n    // Search by display_id in Supabase\n    const { data, error } = await client\n      .from('orders')\n      .select('*')\n      .or(`display_id.eq.${orderNumber.value},id.eq.${orderNumber.value}`)\n      .single()\n\n    if (error || !data) {\n      notFound.value = true\n    } else {\n      const status = data.fulfillment_status || 'not_fulfilled'\n      const isPaid = data.payment_status === 'captured'\n      const isShipped = ['fulfilled', 'shipped', 'delivered'].includes(status)\n      const isDelivered = status === 'delivered'\n      \n      const formatDate = (d: string) => new Date(d).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' })\n      \n      order.value = {\n        number: data.display_id || `TCB-${data.id.slice(0, 8).toUpperCase()}`,\n        delivered: isDelivered,\n        timeline: [\n          { title: 'Commande enregistrée', date: formatDate(data.created_at), detail: 'Votre commande a été validée et prise en charge', completed: true, icon: Package },\n          { title: 'Paiement confirmé', date: isPaid ? formatDate(data.paid_at || data.created_at) : 'En attente', detail: isPaid ? 'Règlement traité avec succès' : 'En attente de confirmation', completed: isPaid, icon: CreditCard },\n          { title: 'Préparation terminée', date: isShipped ? 'Prêt' : 'En attente', detail: isShipped ? 'Votre colis est prêt à être livré' : 'Votre colis est en cours de préparation', completed: isShipped, icon: Clock },\n          { title: 'En cours de livraison', date: isShipped && !isDelivered ? 'En route' : (isDelivered ? 'Livré' : 'En attente'), detail: isShipped ? 'Notre livreur est en route vers le destinataire' : 'Livraison en attente', completed: isShipped, icon: Truck },\n          { title: 'Livré avec succès', date: isDelivered ? formatDate(data.updated_at) : 'En attente', detail: isDelivered ? 'Preuve photo de remise envoyée' : 'Livraison en cours', completed: isDelivered, icon: Camera },\n        ]\n      }\n    }\n  } catch (e) {\n    console.error('Tracking error:', e)\n    notFound.value = true\n  }\n  \n  isSearching.value = false\n}\n\nuseHead({ title: 'Suivre ma commande' })\n</script>\n"],"version":3}
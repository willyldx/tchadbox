{"file":"historique-rntvJTED.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAwFkB,iBAAA;AAClB,UAAM,EAAE,OAAA,IAAW,YAAA;AAGnB,UAAM,UAAU,IAAI,IAAI;AACxB,UAAM,UAAU,IAAa,EAAE;AAC/B,UAAM,kBAAkB,IAAI,CAAC;AAC7B,UAAM,SAAS,IAAI,KAAK;AACxB,UAAM,gBAAgB,IAAmB,IAAI;AAG7C,UAAM,eAAe,SAAS,MAAM;AAClC,YAAM,SAAS,CAAA;AACf,YAAM,0BAAU,KAAA;AAChB,eAAS,IAAI,GAAG,IAAI,GAAG,KAAK;AAC1B,cAAM,OAAO,IAAI,KAAK,IAAI,eAAe,IAAI,SAAA,IAAa,GAAG,CAAC;AAC9D,eAAO,KAAK;AAAA,UACV,OAAO,KAAK,mBAAmB,SAAS,EAAE,OAAO,QAAQ,MAAM,WAAW;AAAA,UAC1E,OAAO,GAAG,KAAK,YAAA,CAAa,IAAI,OAAO,KAAK,SAAA,IAAa,CAAC,EAAE,SAAS,GAAG,GAAG,CAAC;AAAA,QAAA,CAC7E;AAAA,MACH;AACA,aAAO,CAAC,EAAE,OAAO,QAAQ,OAAO,KAAA,GAAQ,GAAG,MAAM;AAAA,IACnD,CAAC;AAGD,UAAM,kBAAkB,SAAS,MAAM;AACrC,UAAI,CAAC,cAAc,MAAO,QAAO,QAAQ;AAEzC,aAAO,QAAQ,MAAM,OAAO,CAAA,MAAK;AAC/B,cAAM,OAAO,IAAI,KAAK,EAAE,eAAe,EAAE,SAAS;AAClD,cAAM,WAAW,GAAG,KAAK,YAAA,CAAa,IAAI,OAAO,KAAK,SAAA,IAAa,CAAC,EAAE,SAAS,GAAG,GAAG,CAAC;AACtF,eAAO,aAAa,cAAc;AAAA,MACpC,CAAC;AAAA,IACH,CAAC;AA8DD,UAAM,cAAc,CAAC,WAAmB;AACtC,aAAO,IAAI,KAAK,aAAa,SAAS,EAAE,OAAO,YAAY,UAAU,MAAA,CAAO,EAAE,OAAO,MAAM;AAAA,IAC7F;AAEA,UAAM,aAAa,CAAC,SAA6B;AAC/C,UAAI,CAAC,KAAM,QAAO;AAClB,aAAO,IAAI,KAAK,IAAI,EAAE,mBAAmB,SAAS;AAAA,QAChD,KAAK;AAAA,QAAW,OAAO;AAAA,QAAS,MAAM;AAAA,QAAW,MAAM;AAAA,QAAW,QAAQ;AAAA,MAAA,CAC3E;AAAA,IACH;AAOA,YAAQ;AAAA,MACN,OAAO;AAAA,IAAA,CACR;;;;;mBAxMMA,eAAAC,WAAA,EAAA,OAAM,eAAW,MAAA,CAAA,kUAU+BC,MAAA,eAAA,CAAe;;QAKtD,MAAK;AAAA,QAAc,OAAM;AAAA,MAAA;0EACgBA,MAAA,MAAA,CAAM,CAAA,2FAAA;;oBAS9CA,MAAA,aAAA;AAAA,kEAAA,cAAa,QAAA,SAAA;AAAA,QACrB,SAASA,MAAA,YAAA;AAAA,QACV,aAAY;AAAA,QACZ,OAAM;AAAA,MAAA;;UAKCA,MAAA,OAAA,GAAO;;;UACT,MAAK;AAAA,UAAoB,OAAM;AAAA,QAAA;;MAIxB,WAAAA,MAAA,eAAA,EAAgB,SAAM,GAAA;;AAEfC,sBAAAD,MAAA,eAAA,IAAZ,aAAQ;4LAMmCE,eAAA,SAAS,SAAS,2DAC5B,WAAW,SAAS,WAAW,CAAA,oEAE3B,YAAY,SAAS,KAAK,CAAA;;YAI9D,MAAK;AAAA,YAAc,OAAM;AAAA,UAAA;AACtB,gBAAA,SAAAA,eAAA,SAAS,aAAa,CAAA,+EAAA;;YAIzB,MAAK;AAAA,YAAiB,OAAM;AAAA,UAAA;wCACzB,SAAS,iBAAiB,QAAI,KAAA,CAAA,eAAA;AAG9B,cAAA,SAAS,eAAa;yDACzB,OAAK,SAAS,aAAa,CAAA,kEAAA;AAAA;;;;;;;;;UAQ7B,MAAK;AAAA,UAAiB,OAAM;AAAA,QAAA;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref","_ssrRenderList","_ssrInterpolate"],"sources":["../../../../pages/livreur/historique.vue"],"sourcesContent":["<template>\n  <div class=\"px-4 py-6\">\n    <!-- Header -->\n    <div class=\"mb-6\">\n      <h1 class=\"text-2xl font-bold text-gray-900\">Historique</h1>\n      <p class=\"text-gray-500 mt-1\">Toutes vos livraisons passées</p>\n    </div>\n\n    <!-- Stats -->\n    <div class=\"grid grid-cols-2 gap-3 mb-6\">\n      <div class=\"bg-white rounded-xl p-4 shadow-sm border border-gray-100\">\n        <p class=\"text-3xl font-bold text-gray-900\">{{ totalDeliveries }}</p>\n        <p class=\"text-sm text-gray-500\">Livraisons totales</p>\n      </div>\n      <div class=\"bg-white rounded-xl p-4 shadow-sm border border-gray-100\">\n        <div class=\"flex items-center gap-1\">\n          <Icon name=\"lucide:star\" class=\"w-6 h-6 text-amber-500 fill-current\" />\n          <p class=\"text-3xl font-bold text-gray-900\">{{ rating }}</p>\n        </div>\n        <p class=\"text-sm text-gray-500\">Note moyenne</p>\n      </div>\n    </div>\n\n    <!-- Filter by month -->\n    <div class=\"mb-4\">\n      <USelectMenu\n        v-model=\"selectedMonth\"\n        :options=\"monthOptions\"\n        placeholder=\"Filtrer par mois\"\n        class=\"w-full\"\n      />\n    </div>\n\n    <!-- Loading -->\n    <div v-if=\"loading\" class=\"flex items-center justify-center py-12\">\n      <UIcon name=\"i-lucide-loader-2\" class=\"w-8 h-8 animate-spin text-green-500\" />\n    </div>\n\n    <!-- Deliveries List -->\n    <div v-else-if=\"filteredHistory.length > 0\" class=\"space-y-3\">\n      <div\n        v-for=\"delivery in filteredHistory\"\n        :key=\"delivery.id\"\n        class=\"bg-white rounded-xl p-4 shadow-sm border border-gray-100\"\n      >\n        <div class=\"flex items-start justify-between mb-2\">\n          <div>\n            <span class=\"font-semibold text-gray-900\">#{{ delivery.displayId }}</span>\n            <p class=\"text-sm text-gray-500\">{{ formatDate(delivery.deliveredAt) }}</p>\n          </div>\n          <span class=\"font-bold text-green-600\">{{ formatPrice(delivery.total) }}</span>\n        </div>\n        \n        <div class=\"flex items-center gap-2 text-sm text-gray-600\">\n          <Icon name=\"lucide:user\" class=\"w-4 h-4 text-gray-400\" />\n          <span>{{ delivery.recipientName }}</span>\n        </div>\n        \n        <div class=\"flex items-center gap-2 text-sm text-gray-600 mt-1\">\n          <Icon name=\"lucide:map-pin\" class=\"w-4 h-4 text-gray-400\" />\n          <span>{{ delivery.shippingAddress?.city || 'N/A' }}</span>\n        </div>\n\n        <div v-if=\"delivery.deliveryPhoto\" class=\"mt-3\">\n          <img :src=\"delivery.deliveryPhoto\" alt=\"Preuve\" class=\"w-full h-24 object-cover rounded-lg\" />\n        </div>\n      </div>\n    </div>\n\n    <!-- Empty State -->\n    <div v-else class=\"text-center py-12\">\n      <div class=\"w-20 h-20 mx-auto mb-4 bg-gray-100 rounded-full flex items-center justify-center\">\n        <Icon name=\"lucide:history\" class=\"w-10 h-10 text-gray-400\" />\n      </div>\n      <p class=\"text-gray-500 font-medium\">Aucune livraison</p>\n      <p class=\"text-sm text-gray-400 mt-1\">Votre historique apparaîtra ici</p>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport type { Order } from '~/types'\n\ndefinePageMeta({\n  layout: 'livreur',\n  middleware: ['livreur']\n})\n\nconst authStore = useAuthStore()\nconst { client } = useSupabase()\n\n// State\nconst loading = ref(true)\nconst history = ref<Order[]>([])\nconst totalDeliveries = ref(0)\nconst rating = ref('5.0')\nconst selectedMonth = ref<string | null>(null)\n\n// Month options\nconst monthOptions = computed(() => {\n  const months = []\n  const now = new Date()\n  for (let i = 0; i < 6; i++) {\n    const date = new Date(now.getFullYear(), now.getMonth() - i, 1)\n    months.push({\n      label: date.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' }),\n      value: `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`\n    })\n  }\n  return [{ label: 'Tous', value: null }, ...months]\n})\n\n// Filtered history\nconst filteredHistory = computed(() => {\n  if (!selectedMonth.value) return history.value\n  \n  return history.value.filter(d => {\n    const date = new Date(d.deliveredAt || d.createdAt)\n    const monthKey = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`\n    return monthKey === selectedMonth.value\n  })\n})\n\n// Fetch history\nconst fetchHistory = async () => {\n  if (!authStore.user) return\n  \n  loading.value = true\n  try {\n    // Fetch delivered orders\n    const { data, error } = await client\n      .from('orders')\n      .select('*')\n      .eq('assigned_to', authStore.user.id)\n      .eq('fulfillment_status', 'delivered')\n      .order('delivered_at', { ascending: false })\n\n    if (error) throw error\n\n    history.value = (data || []).map(mapOrder)\n    totalDeliveries.value = history.value.length\n\n    // Fetch agent stats\n    const { data: agent } = await client\n      .from('delivery_agents')\n      .select('total_deliveries, rating')\n      .eq('user_id', authStore.user.id)\n      .single()\n\n    if (agent) {\n      totalDeliveries.value = agent.total_deliveries || history.value.length\n      rating.value = Number(agent.rating).toFixed(1)\n    }\n  } catch (error) {\n    console.error('Error fetching history:', error)\n  } finally {\n    loading.value = false\n  }\n}\n\n// Map order\nconst mapOrder = (o: any): Order => ({\n  id: o.id,\n  displayId: o.display_id || o.id.slice(0, 8).toUpperCase(),\n  status: o.status,\n  paymentStatus: o.payment_status,\n  fulfillmentStatus: o.fulfillment_status,\n  items: [],\n  shippingAddress: o.shipping_address,\n  subtotal: Number(o.subtotal) || 0,\n  shippingTotal: Number(o.shipping_total) || 0,\n  total: Number(o.total) || 0,\n  currency: o.currency || 'EUR',\n  createdAt: o.created_at,\n  updatedAt: o.updated_at,\n  email: o.email,\n  recipientName: o.recipient_name || 'N/A',\n  recipientPhone: o.recipient_phone,\n  deliveredAt: o.delivered_at,\n  deliveryPhoto: o.delivery_photo\n})\n\n// Helpers\nconst formatPrice = (amount: number) => {\n  return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR' }).format(amount)\n}\n\nconst formatDate = (date: string | undefined) => {\n  if (!date) return '-'\n  return new Date(date).toLocaleDateString('fr-FR', { \n    day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit'\n  })\n}\n\n// Fetch on mount\nonMounted(() => {\n  fetchHistory()\n})\n\nuseHead({\n  title: 'Historique - TchadBox Livreur'\n})\n</script>\n"],"version":3}
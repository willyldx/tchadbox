{"file":"register-BE2iz_wh.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;AAsSA,eAAW;AAAA,MACT,OAAO;AAAA,MACP,aAAa;AAAA,IAAA,CACd;AAED,UAAM,YAAY,aAAA;AAElB,UAAM,OAAO,SAAS;AAAA,MACpB,WAAW;AAAA,MACX,UAAU;AAAA,MACV,OAAO;AAAA,MACP,OAAO;AAAA,MACP,UAAU;AAAA,MACV,iBAAiB;AAAA,MACjB,aAAa;AAAA,IAAA,CACd;AAED,UAAM,eAAe,IAAI,KAAK;AAC9B,UAAM,cAAc,IAAI,KAAK;AAG7B,UAAM,mBAAmB,SAAS,MAAM;AACtC,YAAM,WAAW,KAAK;AACtB,UAAI,CAAC,SAAU,QAAO;AAEtB,UAAI,WAAW;AACf,UAAI,SAAS,UAAU,EAAG;AAC1B,UAAI,SAAS,UAAU,EAAG;AAC1B,UAAI,QAAQ,KAAK,QAAQ,KAAK,QAAQ,KAAK,QAAQ,EAAG;AACtD,UAAI,QAAQ,KAAK,QAAQ,KAAK,eAAe,KAAK,QAAQ,EAAG;AAE7D,aAAO;AAAA,IACT,CAAC;AAED,UAAM,iBAAiB,CAAC,IAAI,UAAU,SAAS,OAAO,WAAW;AACjE,UAAM,iBAAiB,CAAC,cAAc,iBAAiB,iBAAiB,cAAc;AACtF,UAAM,qBAAqB,CAAC,gBAAgB,mBAAmB,mBAAmB,gBAAgB;AAElG,UAAM,iBAAiB,SAAS,MAAM;AACpC,aAAO,KAAK,aAAa,KAAK;AAAA,IAChC,CAAC;AAED,UAAM,cAAc,SAAS,MAAM;AACjC,aACE,KAAK,aACL,KAAK,YACL,KAAK,SACL,KAAK,SAAS,UAAU,KACxB,eAAe,SACf,KAAK;AAAA,IAET,CAAC;;;AAxVM,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,kFAA8E,MAAA,CAAA,CAAA,4OAAA;;QAS3E,IAAG;AAAA,QAAI,OAAM;AAAA,MAAA;yBAAvB,CAOW,GAAAC,QAAAC,UAAA,aAAA;;;;;cANTC,YAIM,OAAA,EAJD,OAAM,yLAAqL;AAAA,8BAC9LC,YAEM,OAAA;AAAA,kBAFD,OAAM;AAAA,kBAAqB,MAAK;AAAA,kBAAO,QAAO;AAAA,kBAAe,SAAQ;AAAA,gBAAA;kBACxED,YAA4I,QAAA;AAAA,oBAAtI,kBAAe;AAAA,oBAAQ,mBAAgB;AAAA,oBAAQ,gBAAa;AAAA,oBAAI,GAAE;AAAA,kBAAA;;;cAG5EA,YAAyE,QAAA,EAAnE,OAAM,8CAAA,GAA8C,UAAQ;AAAA,YAAA;AAAA;;;;;UAgBrDE,MAAA,WAAA,GAAW;;;;;AAsBX,UAAAA,MAAA,SAAA,EAAU,OAAK;AAIW,cAAA,4WAAAC,eAAAD,MAAA,SAAA,EAAU,KAAK,CAAA,YAAA;AAAA;;;sNAcrCE,cAAA,SAAAF,MAAA,IAAA,EAAK,SAAS,oFAMZG,sBAAAH,MAAA,SAAA,EAAU,SAAS,IAAA,cAAA,kJASrBE,cAAA,SAAAF,MAAA,IAAA,EAAK,QAAQ,uFAMXG,sBAAAH,MAAA,SAAA,EAAU,SAAS,IAAA,cAAA,gjBAkBrBE,cAAA,SAAAF,MAAA,IAAA,EAAK,KAAK,kHAMnB,EAAA,gBAAA,OAAA,CAA2B,KAChBG,sBAAAH,MAAA,SAAA,EAAU,SAAS,IAAA,cAAA,wuBAkBrBE,cAAA,SAAAF,MAAA,IAAA,EAAK,KAAK,sGAKnB,EAAA,gBAAA,OAAA,CAA2B,KAChBG,sBAAAH,MAAA,SAAA,EAAU,SAAS,IAAA,cAAA,2kBAmBvBA,MAAA,YAAA,IAAY,SAAA,YADVA,MAAA,IAAA,EAAK,UAAQ,IAAA,IACrBE,cAAA,QAAMF,MAAA,YAAA,IAAY,SAAA,UAAA,mHAMnB,EAAA,gBAAA,QAAA,iBAAA,OAAA,CAAgD,KACrCG,sBAAAH,MAAA,SAAA,EAAU,SAAS,IAAA,cAAA;WAOlBA,MAAA,YAAA,GAAY;;;;;;AAaVI,oBAAA,IAAL,MAAC;AAGA,cAAA,eAAAC,eAAA,CAAA,KAAKL,MAAA,gBAAA,IAAmB,eAAeA,MAAA,gBAAA,IAAgB,CAAA,IAAA,eAAA,2CAAA,CAAA,CAAA,UAAA;AAAA;;AAG1D,UAAAA,MAAA,IAAA,EAAK,UAAQ;2BAA+BK,eAAA,CAAA,mBAAmBL,MAAA,gBAAA,IAAgB,CAAA,KAAA,kCAAA,cAAA,CAAA,MACnFC,eAAA,eAAeD,MAAA,gBAAA,CAAgB,KAAA,wBAAA;;;;ysBAmB3BA,MAAA,YAAA,IAAY,SAAA,YADVA,MAAA,IAAA,EAAK,iBAAe,IAAA,IAC5BE,cAAA,QAAMF,MAAA,YAAA,IAAY,SAAA,UAAA,uFAKnB,EAAA,gBAAA,OAAA,CAA2B,sEACsBA,MAAA,IAAA,EAAK,mBAAe,CAAKA,MAAA,cAAA,EAAA,GAAc,OAAA,CAAA,KAC7EG,sBAAAH,MAAA,SAAA,EAAU,SAAS,IAAA,cAAA;UAGzBA,MAAA,IAAA,EAAK,mBAAe,CAAKA,MAAA,cAAA,GAAc;;;;;AASrC,YAAA,wDAAAG,sBAAA,MAAA,QAAAH,MAAA,IAAA,EAAK,WAAW,IAAhBM,gBAAAN,MAAA,IAAA,EAAK,aAAW,IAAA,IAAhBA,MAAA,IAAA,EAAK,WAAW,IAAA,aAAA,EAAA,8OAAA;;QAOf,IAAG;AAAA,QAAc,OAAM;AAAA,MAAA;yBAAjC,CAAqG,GAAAJ,QAAAC,UAAA,aAAA;;;;;8BAAnC,0BAAwB;AAAA,YAAA;AAAA;;;;;;QAEhF,IAAG;AAAA,QAAmB,OAAM;AAAA,MAAA;yBAAtC,CAA8G,GAAAD,QAAAC,UAAA,aAAA;;;;;8BAAvC,8BAA4B;AAAA,YAAA;AAAA;;;;wEAO1FG,MAAA,SAAA,EAAU,aAAS,CAAKA,MAAA,WAAA,CAAW,IAAA,cAAA,EAAA,qIAAA;AAGnC,UAAAA,MAAA,SAAA,EAAU,WAAS;;;;;AAIrB,YAAA,SAAAC,eAAAD,MAAA,SAAA,EAAU,YAAS,gBAAA,kBAAA,CAAA,0GAAA;;QAOpB,IAAG;AAAA,QAAc,OAAM;AAAA,MAAA;yBAAjC,CAEW,GAAAJ,QAAAC,UAAA,aAAA;;;;;8BAFyH,gBAEpI;AAAA,YAAA;AAAA;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_push","_parent","_createVNode","_createBlock","_unref","_ssrInterpolate","_ssrRenderAttr","_ssrIncludeBooleanAttr","_ssrRenderList","_ssrRenderClass","_ssrLooseContain"],"sources":["../../../../pages/auth/register.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-screen bg-[var(--color-bg)] flex items-center justify-center p-4 py-12\">\n    <!-- Background decoration -->\n    <div class=\"absolute inset-0 overflow-hidden pointer-events-none\">\n      <div class=\"orb orb-amber w-80 h-80 -top-40 -right-40\"></div>\n      <div class=\"orb orb-warm w-80 h-80 -bottom-40 -left-40\"></div>\n    </div>\n\n    <div class=\"w-full max-w-md relative\">\n      <!-- Logo -->\n      <NuxtLink to=\"/\" class=\"flex items-center justify-center gap-3 mb-8 group\">\n        <div class=\"w-12 h-12 bg-gradient-to-br from-amber-500 to-amber-600 rounded-xl flex items-center justify-center shadow-lg shadow-amber-500/25 group-hover:shadow-amber-500/40 transition-shadow\">\n          <svg class=\"w-7 h-7 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4\" />\n          </svg>\n        </div>\n        <span class=\"text-2xl font-bold text-[var(--color-text)]\">TchadBox</span>\n      </NuxtLink>\n\n      <!-- Register Card -->\n      <div class=\"card-glass rounded-2xl shadow-xl p-8\">\n        <div class=\"text-center mb-8\">\n          <h1 class=\"text-2xl font-bold text-[var(--color-text)] mb-2\">Créer un compte</h1>\n          <p class=\"text-[var(--color-text-muted)]\">Rejoignez TchadBox et envoyez vos colis</p>\n        </div>\n\n        <!-- Success Message -->\n        <Transition\n          enter-active-class=\"transition-all duration-300\"\n          enter-from-class=\"opacity-0 -translate-y-2\"\n          enter-to-class=\"opacity-100 translate-y-0\"\n        >\n          <div v-if=\"showSuccess\" class=\"mb-6 p-4 bg-green-50 border border-green-100 rounded-xl\">\n            <div class=\"flex items-start gap-3\">\n              <svg class=\"w-5 h-5 text-green-500 mt-0.5 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\" />\n              </svg>\n              <div>\n                <p class=\"text-sm font-medium text-green-800\">Compte créé avec succès !</p>\n                <p class=\"text-sm text-green-600 mt-1\">Vérifiez votre email pour confirmer votre compte.</p>\n              </div>\n            </div>\n          </div>\n        </Transition>\n\n        <!-- Error Alert -->\n        <Transition\n          enter-active-class=\"transition-all duration-300\"\n          enter-from-class=\"opacity-0 -translate-y-2\"\n          enter-to-class=\"opacity-100 translate-y-0\"\n          leave-active-class=\"transition-all duration-200\"\n          leave-from-class=\"opacity-100\"\n          leave-to-class=\"opacity-0\"\n        >\n          <div v-if=\"authStore.error\" class=\"mb-6 p-4 bg-red-50 border border-red-100 rounded-xl flex items-start gap-3\">\n            <svg class=\"w-5 h-5 text-red-500 mt-0.5 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" />\n            </svg>\n            <p class=\"text-sm text-red-600\">{{ authStore.error }}</p>\n          </div>\n        </Transition>\n\n        <!-- Register Form -->\n        <form @submit.prevent=\"handleSubmit\" class=\"space-y-5\">\n          <!-- Name Fields -->\n          <div class=\"grid grid-cols-2 gap-4\">\n            <div>\n              <label for=\"firstName\" class=\"block text-sm font-medium text-[var(--color-text-secondary)] mb-2\">\n                Prénom\n              </label>\n              <input\n                id=\"firstName\"\n                v-model=\"form.firstName\"\n                type=\"text\"\n                required\n                autocomplete=\"given-name\"\n                placeholder=\"Jean\"\n                class=\"input\"\n                :disabled=\"authStore.isLoading\"\n              />\n            </div>\n            <div>\n              <label for=\"lastName\" class=\"block text-sm font-medium text-[var(--color-text-secondary)] mb-2\">\n                Nom\n              </label>\n              <input\n                id=\"lastName\"\n                v-model=\"form.lastName\"\n                type=\"text\"\n                required\n                autocomplete=\"family-name\"\n                placeholder=\"Dupont\"\n                class=\"input\"\n                :disabled=\"authStore.isLoading\"\n              />\n            </div>\n          </div>\n\n          <!-- Email -->\n          <div>\n            <label for=\"email\" class=\"block text-sm font-medium text-[var(--color-text-secondary)] mb-2\">\n              Adresse email\n            </label>\n            <div class=\"relative\">\n              <div class=\"absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none\">\n                <svg class=\"w-5 h-5 text-[var(--color-text-muted)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z\" />\n                </svg>\n              </div>\n              <input\n                id=\"email\"\n                v-model=\"form.email\"\n                type=\"email\"\n                required\n                autocomplete=\"email\"\n                placeholder=\"votre@email.com\"\n                class=\"input\"\n                style=\"padding-left: 3rem;\"\n                :disabled=\"authStore.isLoading\"\n              />\n            </div>\n          </div>\n\n          <!-- Phone -->\n          <div>\n            <label for=\"phone\" class=\"block text-sm font-medium text-[var(--color-text-secondary)] mb-2\">\n              Téléphone <span class=\"text-[var(--color-text-muted)] font-normal\">(optionnel)</span>\n            </label>\n            <div class=\"relative\">\n              <div class=\"absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none\">\n                <svg class=\"w-5 h-5 text-[var(--color-text-muted)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z\" />\n                </svg>\n              </div>\n              <input\n                id=\"phone\"\n                v-model=\"form.phone\"\n                type=\"tel\"\n                autocomplete=\"tel\"\n                placeholder=\"+235 XX XX XX XX\"\n                class=\"input\"\n                style=\"padding-left: 3rem;\"\n                :disabled=\"authStore.isLoading\"\n              />\n            </div>\n          </div>\n\n          <!-- Password -->\n          <div>\n            <label for=\"password\" class=\"block text-sm font-medium text-[var(--color-text-secondary)] mb-2\">\n              Mot de passe\n            </label>\n            <div class=\"relative\">\n              <div class=\"absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none\">\n                <svg class=\"w-5 h-5 text-[var(--color-text-muted)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" />\n                </svg>\n              </div>\n              <input\n                id=\"password\"\n                v-model=\"form.password\"\n                :type=\"showPassword ? 'text' : 'password'\"\n                required\n                autocomplete=\"new-password\"\n                placeholder=\"••••••••\"\n                minlength=\"6\"\n                class=\"input\"\n                style=\"padding-left: 3rem; padding-right: 3rem;\"\n                :disabled=\"authStore.isLoading\"\n              />\n              <button\n                type=\"button\"\n                @click=\"showPassword = !showPassword\"\n                class=\"absolute inset-y-0 right-0 pr-4 flex items-center\"\n              >\n                <svg v-if=\"!showPassword\" class=\"w-5 h-5 text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z\" />\n                </svg>\n                <svg v-else class=\"w-5 h-5 text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21\" />\n                </svg>\n              </button>\n            </div>\n            <!-- Password strength indicator -->\n            <div class=\"mt-2\">\n              <div class=\"flex gap-1\">\n                <div \n                  v-for=\"i in 4\" \n                  :key=\"i\" \n                  class=\"h-1 flex-1 rounded-full transition-colors\"\n                  :class=\"i <= passwordStrength ? strengthColors[passwordStrength - 1] : 'bg-gray-200'\"\n                ></div>\n              </div>\n              <p v-if=\"form.password\" class=\"text-xs mt-1\" :class=\"strengthTextColors[passwordStrength - 1] || 'text-[var(--color-text-muted)]'\">\n                {{ strengthLabels[passwordStrength] || 'Entrez un mot de passe' }}\n              </p>\n            </div>\n          </div>\n\n          <!-- Confirm Password -->\n          <div>\n            <label for=\"confirmPassword\" class=\"block text-sm font-medium text-[var(--color-text-secondary)] mb-2\">\n              Confirmer le mot de passe\n            </label>\n            <div class=\"relative\">\n              <div class=\"absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none\">\n                <svg class=\"w-5 h-5 text-[var(--color-text-muted)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\" />\n                </svg>\n              </div>\n              <input\n                id=\"confirmPassword\"\n                v-model=\"form.confirmPassword\"\n                :type=\"showPassword ? 'text' : 'password'\"\n                required\n                autocomplete=\"new-password\"\n                placeholder=\"••••••••\"\n                class=\"input\"\n                style=\"padding-left: 3rem;\"\n                :class=\"{ 'border-red-300 focus:border-red-500': form.confirmPassword && !passwordsMatch }\"\n                :disabled=\"authStore.isLoading\"\n              />\n            </div>\n            <p v-if=\"form.confirmPassword && !passwordsMatch\" class=\"text-xs text-red-500 mt-1\">\n              Les mots de passe ne correspondent pas\n            </p>\n          </div>\n\n          <!-- Terms -->\n          <div class=\"flex items-start\">\n            <input\n              id=\"terms\"\n              v-model=\"form.acceptTerms\"\n              type=\"checkbox\"\n              required\n              class=\"w-4 h-4 mt-0.5 text-amber-500 border-gray-300 rounded focus:ring-amber-500/20 cursor-pointer\"\n            />\n            <label for=\"terms\" class=\"ml-2 text-sm text-[var(--color-text-secondary)] cursor-pointer\">\n              J'accepte les \n              <NuxtLink to=\"/conditions\" class=\"text-amber-600 hover:underline\">conditions d'utilisation</NuxtLink>\n              et la \n              <NuxtLink to=\"/confidentialite\" class=\"text-amber-600 hover:underline\">politique de confidentialité</NuxtLink>\n            </label>\n          </div>\n\n          <!-- Submit Button -->\n          <button\n            type=\"submit\"\n            :disabled=\"authStore.isLoading || !isFormValid\"\n            class=\"w-full py-3.5 btn-gold !rounded-xl disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2\"\n          >\n            <svg v-if=\"authStore.isLoading\" class=\"w-5 h-5 animate-spin\" fill=\"none\" viewBox=\"0 0 24 24\">\n              <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle>\n              <path class=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n            </svg>\n            <span>{{ authStore.isLoading ? 'Création...' : 'Créer mon compte' }}</span>\n          </button>\n        </form>\n\n        <!-- Login Link -->\n        <p class=\"text-center text-[var(--color-text-secondary)] mt-8\">\n          Déjà un compte ?\n          <NuxtLink to=\"/auth/login\" class=\"text-[var(--color-accent-dark)] hover:text-[var(--color-accent)] font-semibold transition-colors\">\n            Se connecter\n          </NuxtLink>\n        </p>\n      </div>\n\n      <!-- Trust badges -->\n      <div class=\"flex items-center justify-center gap-6 mt-8\">\n        <div class=\"flex items-center gap-2 text-xs text-[var(--color-text-muted)]\">\n          <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" />\n          </svg>\n          <span>SSL sécurisé</span>\n        </div>\n        <div class=\"flex items-center gap-2 text-xs text-[var(--color-text-muted)]\">\n          <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\" />\n          </svg>\n          <span>Données protégées</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefinePageMeta({\n  layout: false,\n  middleware: ['auth'],\n})\n\nuseSeoMeta({\n  title: 'Créer un compte - TchadBox',\n  description: 'Créez votre compte TchadBox et commencez à envoyer des colis de la France vers le Tchad.',\n})\n\nconst authStore = useAuthStore()\n\nconst form = reactive({\n  firstName: '',\n  lastName: '',\n  email: '',\n  phone: '',\n  password: '',\n  confirmPassword: '',\n  acceptTerms: false,\n})\n\nconst showPassword = ref(false)\nconst showSuccess = ref(false)\n\n// Password strength calculation\nconst passwordStrength = computed(() => {\n  const password = form.password\n  if (!password) return 0\n  \n  let strength = 0\n  if (password.length >= 6) strength++\n  if (password.length >= 8) strength++\n  if (/[A-Z]/.test(password) && /[a-z]/.test(password)) strength++\n  if (/[0-9]/.test(password) || /[^A-Za-z0-9]/.test(password)) strength++\n  \n  return strength\n})\n\nconst strengthLabels = ['', 'Faible', 'Moyen', 'Bon', 'Excellent']\nconst strengthColors = ['bg-red-400', 'bg-orange-400', 'bg-yellow-400', 'bg-green-400']\nconst strengthTextColors = ['text-red-500', 'text-orange-500', 'text-yellow-600', 'text-green-500']\n\nconst passwordsMatch = computed(() => {\n  return form.password === form.confirmPassword\n})\n\nconst isFormValid = computed(() => {\n  return (\n    form.firstName &&\n    form.lastName &&\n    form.email &&\n    form.password.length >= 6 &&\n    passwordsMatch.value &&\n    form.acceptTerms\n  )\n})\n\n// Clear errors when component mounts\nonMounted(() => {\n  authStore.clearError()\n})\n\nasync function handleSubmit() {\n  if (!isFormValid.value) return\n  \n  const result = await authStore.register({\n    email: form.email,\n    password: form.password,\n    firstName: form.firstName,\n    lastName: form.lastName,\n    phone: form.phone || undefined,\n  })\n  \n  if (result.success) {\n    if (result.requiresConfirmation) {\n      showSuccess.value = true\n    } else {\n      navigateTo('/compte')\n    }\n  }\n}\n</script>\n"],"version":3}